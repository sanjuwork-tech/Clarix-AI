# Clarix.ai — Required Environment Variables
# Copy this file to .env and fill in your values for local development.
# In production (Replit), these are set as Secrets in the project dashboard.

# Mercury 2 (Inception Labs) — AI engine for diagnostic reports
# Get your key at: https://inceptionlabs.ai
INCEPTION_API_KEY=your_inception_api_key_here

# Express session secret — generate a long random string
SESSION_SECRET=your_session_secret_here

# PostgreSQL connection string
# In Replit this is auto-provided; for local dev point to your own Postgres instance
DATABASE_URL=postgresql://user:password@localhost:5432/clarix
