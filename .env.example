# Clarix.ai — Environment Variables
# Copy this file to .env and fill in your values.
# In Vercel, add these as Environment Variables in the dashboard.

# Mercury 2 (Inception Labs) — AI engine for diagnostic reports
# Server-side only — used by the /api/diagnostic/analyze serverless function
# Get your key at: https://inceptionlabs.ai
INCEPTION_API_KEY=your_inception_api_key_here
